# ──────────────────────────────────────────────
#  CV Adapter — файл конфигурации
#  Скопируйте этот файл как .env и заполните.
# ──────────────────────────────────────────────

# ID таблицы Google Sheets (из URL: /spreadsheets/d/ВОТ_ЭТО_ЧАСТЬ/edit)
SPREADSHEET_ID=ВАШ_SPREADSHEET_ID

# Названия листов (менять только если отличаются от стандартных)
SHEET_MASTER_CV=Master CV
SHEET_TRACKER=Tracker
SHEET_ADDITIONAL_FILTER=Additional Filter

# Названия колонок в листе Tracker
COL_URL=URL
COL_DESCRIPTION=Description
COL_ADAPTED_CV=Adapted CV
COL_BASE_SCORING=BaseScoring
COL_ADDITIONAL_SCORING=AdditionalScoring
COL_SUMMARY_SCORING=SummaryScoring

# Минимальный порог для продолжения в адаптацию CV
MIN_SUMMARY_SCORE=50
# SummaryScoring = средневзвешенное BaseScoring и AdditionalScoring (оба 0..100), итог 0..100
BASE_SCORING_WEIGHT=0.5
ADDITIONAL_SCORING_WEIGHT=0.5
# (устарело, но поддерживается: SUMMARY_BASE_WEIGHT / SUMMARY_ADDITIONAL_WEIGHT)

# Analyzer — получение текста вакансии
ANALYZER_HTTP_TIMEOUT_SEC=30
ANALYZER_MAX_DESCRIPTION_CHARS=20000
ANALYZER_RATE_LIMIT_SEC=15
# Таблица разбора Base/Additional/Summary в консоль (или включите DEBUG=1)
# ANALYZER_PRINT_SCORE_BREAKDOWN=1

# Отладка: DEBUG=1 — лог шагов приложения; DEBUG_HTTP=1 — дополнительно сырой HTTP (очень шумно)
# PAUSE_ON_EXIT=0 — не ждать Enter в конце (удобно в терминале)
# DEBUG=1
# DEBUG_HTTP=1
# PAUSE_ON_EXIT=0
# Либо запуск без буфера: set PYTHONUNBUFFERED=1

# OAuth файлы (должны лежать рядом с программой)
CLIENT_SECRET_FILE=client_secret.json
TOKEN_FILE=token.json

# ── LLM настройки ──────────────────────────────
# Провайдер: gemini | openai | groq
LLM_PROVIDER=gemini

# Google Gemini (бесплатная квота: 1500 запросов/день)
# Ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=ВАШ_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (раскомментировать при переключении)
# OPENAI_API_KEY=ВАШ_OPENAI_API_KEY
# OPENAI_MODEL=gpt-4o-mini

# Groq (бесплатно, раскомментировать при переключении)
# GROQ_API_KEY=ВАШ_GROQ_API_KEY
# GROQ_MODEL=llama3-8b-8192
